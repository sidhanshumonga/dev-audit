{
  "name": "dev-audit",
  "version": "0.1.0",
  "description": "A lightweight CLI toolkit for keeping your codebase clean",
  "private": true,
  "workspaces": [
    "tools/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint 'tools/*/src/**/*.ts'",
    "lint:fix": "eslint 'tools/*/src/**/*.ts' --fix",
    "format": "prettier --write 'tools/*/src/**/*.ts' 'tools/*/tests/**/*.ts'",
    "format:check": "prettier --check 'tools/*/src/**/*.ts' 'tools/*/tests/**/*.ts'",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "lint-staged": {
    "tools/*/src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tools/*/tests/**/*.ts": [
      "prettier --write"
    ]
  }
}

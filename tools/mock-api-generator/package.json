{
  "name": "@dev-audit/mock-api-generator",
  "version": "0.1.0",
  "description": "Spins up a mock REST API server from TypeScript type definitions",
  "main": "dist/cli/index.js",
  "bin": {
    "dev-audit-mock": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "cli",
    "devtools",
    "mock",
    "api",
    "typescript",
    "faker"
  ],
  "license": "MIT",
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "express": "^4.18.3",
    "ts-morph": "^21.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}

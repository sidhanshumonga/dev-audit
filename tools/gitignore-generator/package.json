{
  "name": "@dev-audit/gitignore-generator",
  "version": "0.1.3",
  "description": "Detects your project stack and generates a tailored .gitignore file",
  "main": "dist/cli/index.js",
  "bin": {
    "dev-audit-gitignore": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "cli",
    "devtools",
    "gitignore",
    "generator",
    "static-analysis",
    "gitignore-generator",
    "stack-detection",
    "nodejs",
    "nextjs",
    "python",
    "docker",
    "code-hygiene",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sidhanshumonga/dev-audit.git",
    "directory": "tools/gitignore-generator"
  },
  "homepage": "https://github.com/sidhanshumonga/dev-audit/tree/main/tools/gitignore-generator#readme",
  "bugs": {
    "url": "https://github.com/sidhanshumonga/dev-audit/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
